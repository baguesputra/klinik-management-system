generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN_KLINIK
  DOKTER
  APOTEKER
  KASIR
  PASIEN
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum AppointmentStatus {
  MENUNGGU
  DIPANGGIL
  SELESAI
  DIBATALKAN
}

enum PrescriptionStatus {
  MENUNGGU
  DIPROSES
  SELESAI
  DIAMBIL_SEBAGIAN
  TIDAK_DIAMBIL
}

enum PaymentMethod {
  TUNAI
  BRI
  BNI
  BCA
  MANDIRI
  BSI
  QRIS
  OVO
  GOPAY
  DANA
  SHOPEEPAY
  BPJS
  ASURANSI_SWASTA
}

enum PaymentStatus {
  BELUM_BAYAR
  LUNAS
  SEBAGIAN
}

enum VoidStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StockMutationType {
  MASUK
  KELUAR
  ADJUSTMENT
}

// ─── MODELS ──────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  name         String
  phone        String?
  role         Role     @default(PASIEN)
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  googleId     String?  @unique
  avatarUrl    String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctor        Doctor?
  patient       Patient?
  auditLogs     AuditLog[]
  kasirPayments Payment[]            @relation("KasirPayments")
  voidRequests  PaymentVoidRequest[] @relation("VoidRequester")
  voidReviews   PaymentVoidRequest[] @relation("VoidReviewer")

  @@map("users")
}

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique
  specialization String
  licenseNumber  String  @unique
  schedule       Json    // { monday: ["08:00", "12:00"], ... }
  consultFee Decimal @db.Decimal(12, 2) @default(150000)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("doctors")
}

model Patient {
  id           String   @id @default(uuid())
  userId       String   @unique
  medicalRecordNo String @unique @default(cuid())
  dateOfBirth  DateTime
  gender       Gender
  address      String?
  bloodType    String?
  allergies    String?
  emergencyContact String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  medicalRecords MedicalRecord[]

  @@map("patients")
}

model Appointment {
  id         String            @id @default(uuid())
  patientId  String
  doctorId   String
  date       DateTime
  queueNumber Int
  complaint  String?
  status     AppointmentStatus @default(MENUNGGU)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  medicalRecord MedicalRecord?
  billing       Billing?

  @@map("appointments")
}

model MedicalRecord {
  id            String   @id @default(uuid())
  patientId     String
  appointmentId String   @unique
  diagnosis     String
  notes         String?
  bloodPressure String?
  weight        Float?
  height        Float?
  temperature   Float?
  createdAt     DateTime @default(now())

  patient      Patient      @relation(fields: [patientId], references: [id])
  appointment  Appointment  @relation(fields: [appointmentId], references: [id])
  prescription Prescription?

  @@map("medical_records")
}

model Medicine {
  id           String   @id @default(uuid())
  name         String
  genericName  String?
  category     String
  unit         String   // tablet, kapsul, ml, dll
  price        Decimal  @db.Decimal(12, 2)
  stock        Int      @default(0)
  minStock     Int      @default(10)
  description  String?
  expiryDate   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stockMutations   StockMutation[]
  prescriptionItems PrescriptionItem[]

  @@map("medicines")
}

model StockMutation {
  id         String            @id @default(uuid())
  medicineId String
  type       StockMutationType
  quantity   Int
  reason     String?
  createdAt  DateTime          @default(now())

  medicine Medicine @relation(fields: [medicineId], references: [id])

  @@map("stock_mutations")
}

model Prescription {
  id              String             @id @default(uuid())
  medicalRecordId String             @unique
  status          PrescriptionStatus @default(MENUNGGU)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  medicalRecord MedicalRecord      @relation(fields: [medicalRecordId], references: [id])
  items         PrescriptionItem[]

  @@map("prescriptions")
}

model PrescriptionItem {
  id             String @id @default(uuid())
  prescriptionId String
  medicineId     String
  quantity       Int
  dosage         String // "3x1 sesudah makan"
  notes          String?

  quantityDispensed Int @default(0)

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  medicine     Medicine     @relation(fields: [medicineId], references: [id])

  @@map("prescription_items")
}

model Billing {
  id            String        @id @default(uuid())
  appointmentId String        @unique
  invoiceNumber String        @unique
  consultFee    Decimal       @db.Decimal(12, 2)
  medicineFee   Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount   Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus @default(BELUM_BAYAR)
  paidAt        DateTime?
  notes         String?
  paidAmount        Decimal   @db.Decimal(12, 2) @default(0)
  isBpjs            Boolean   @default(false)
  bpjsNo            String?
  bpjsCoveredAmount Decimal?  @db.Decimal(12, 2)
  insuranceProvider String?
  insuranceClaimNo  String?
  insuranceCovered  Decimal?  @db.Decimal(12, 2)
  payments          Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@map("billings")
}

model Payment {
  id          String        @id @default(uuid())
  billingId   String
  amount      Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @db.Decimal(12, 2)
  change      Decimal       @db.Decimal(12, 2) @default(0)
  method      PaymentMethod
  referenceNo String?
  notes       String?
  isVoid      Boolean       @default(false)
  createdBy   String
  createdAt   DateTime      @default(now())

  billing     Billing            @relation(fields: [billingId], references: [id])
  kasir       User               @relation("KasirPayments", fields: [createdBy], references: [id])
  voidRequest PaymentVoidRequest?

  @@map("payments")
}

model PaymentVoidRequest {
  id          String     @id @default(uuid())
  paymentId   String     @unique
  reason      String
  status      VoidStatus @default(PENDING)
  requestedBy String
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime   @default(now())

  payment   Payment @relation(fields: [paymentId], references: [id])
  requester User    @relation("VoidRequester", fields: [requestedBy], references: [id])
  reviewer  User?   @relation("VoidReviewer", fields: [reviewedBy], references: [id])

  @@map("payment_void_requests")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}